{
  "name": "4rm0byte",
  "version": "1.0.0",
  "description": "My Personal Blogging Website build using Hugo , Blowfish theme and Decap CMS.",
  "private": true,
  "scripts": {
    "postinstall": "vendor-copy",
    "start": "concurrently \"npm run dev\" \"npm run decap-dev\"",
    "decap-dev": "npx decap-server",
    "dev": "hugo server --buildDrafts --buildFuture --buildExpired --gc --logLevel info --watch",
    "prod": "hugo server --buildDrafts --buildFuture --buildExpired --gc --logLevel info --watch -e production",
    "build": "hugo --gc --logLevel info --cleanDestinationDir --minify",
    "update": "npm update",
    "depcheck": "depcheck",
    "clean-logs": "rimraf hugo.build.lock && find . -name '*.log' -type f -delete",
    "hbuild": "hugo -d ./4rm0Byte-Public"
  },
  "keywords": [
    "4rm0byte",
    "Hugo",
    "Decap CMS",
    "Blowfish Theme",
    "Blogging Website",
    "Personal Blog"
  ],
  "engines": {
    "node": ">=21.7.3",
    "npm": ">=10.5.0",
    "hugo": ">=0.157.0"
  },
  "dependencies": {
    "decap-cms-app": "^3.14.1",
    "netlify-identity-widget": "^2.0.3",
    "workbox-sw": "^7.4.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "depcheck": "^1.4.7",
    "prettier": "^3.9.5",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-toml": "^2.0.6",
    "rimraf": "^6.1.3",
    "vendor-copy": "^3.0.1"
  },
  "author": {
    "name": "Armoghan-ul-Mohmin",
    "email": "armoghanblogs@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Armoghan-Blogs/4rm0Byte.git",
    "description": "A personal blog built with Hugo and Decap-CMS, using the Blowfish theme."
  },
  "bugs": {
    "url": "https://github.com/Armoghan-Blogs/4rm0Byte/issues"
  },
  "homepage": "https://github.com/Armoghan-Blogs/4rm0Byte#readme",
  "vendorCopy": [
    {
      "from": "/node_modules/workbox-sw/build/workbox-sw.js",
      "to": "/static/lib/workbox/workbox-sw.js"
    },
    {
      "from": "/node_modules/workbox-sw/build/workbox-sw.js.map",
      "to": "/static/lib/workbox/workbox-sw.js.map"
    },
    {
      "from": "node_modules/netlify-identity-widget/build/netlify-identity-widget.js",
      "to": "/assets/lib/netlify-identity-widget/netlify-identity-widget.js"
    },
    {
      "from": "node_modules/netlify-identity-widget/build/netlify-identity-widget.js.map",
      "to": "/assets/lib/netlify-identity-widget/netlify-identity-widget.js.map"
    }
  ]
}
